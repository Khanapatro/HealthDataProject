{
	"$schema": "http://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
	"contentVersion": "1.0.0.0",
	"parameters": {
		"factoryName": {
			"type": "string",
			"metadata": "Data Factory name",
			"defaultValue": "healthdetailadf"
		},
		"AzureDatabricksDeltaLake_accessToken": {
			"type": "secureString",
			"metadata": "Secure string for 'accessToken' of 'AzureDatabricksDeltaLake'"
		},
		"database_ls_password": {
			"type": "secureString",
			"metadata": "Secure string for 'password' of 'database_ls'"
		},
		"hospitalstorage_accountKey": {
			"type": "secureString",
			"metadata": "Secure string for 'accountKey' of 'hospitalstorage'"
		},
		"database_ls_properties_typeProperties_server": {
			"type": "string",
			"defaultValue": "hospitalsserver.database.windows.net"
		},
		"database_ls_properties_typeProperties_database": {
			"type": "string",
			"defaultValue": "@{linkedService().db_name}"
		},
		"database_ls_properties_typeProperties_userName": {
			"type": "string",
			"defaultValue": "hospitaladmin"
		},
		"hospitalstorage_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://healthdetails.dfs.core.windows.net/"
		},
		"containerUri": {
			"type": "string",
			"metadata": "URI to storage account containing linked ARM templates"
		},
		"containerSasToken": {
			"type": "string",
			"metadata": "Sas token to storage account containing linked ARM templates"
		}
	},
	"variables": {
		"factoryId": "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'))]"
	},
	"resources": [
		{
			"name": "healthdetailadf_ArmTemplate_0",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2024-03-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_0.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
				},
				"parameters": {
					"factoryName": {
						"value": "[parameters('factoryName')]"
					},
					"AzureDatabricksDeltaLake_accessToken": {
						"value": "[parameters('AzureDatabricksDeltaLake_accessToken')]"
					},
					"database_ls_password": {
						"value": "[parameters('database_ls_password')]"
					},
					"hospitalstorage_accountKey": {
						"value": "[parameters('hospitalstorage_accountKey')]"
					},
					"database_ls_properties_typeProperties_server": {
						"value": "[parameters('database_ls_properties_typeProperties_server')]"
					},
					"database_ls_properties_typeProperties_database": {
						"value": "[parameters('database_ls_properties_typeProperties_database')]"
					},
					"database_ls_properties_typeProperties_userName": {
						"value": "[parameters('database_ls_properties_typeProperties_userName')]"
					},
					"hospitalstorage_properties_typeProperties_url": {
						"value": "[parameters('hospitalstorage_properties_typeProperties_url')]"
					}
				}
			},
			"dependsOn": []
		}
	]
}